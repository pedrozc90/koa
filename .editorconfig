[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
tab_width = 4
ij_continuation_indent_size = 4

[*.java]
ij_continuation_indent_size = 4
ij_java_spaces_within_array_initializer_braces = true
ij_java_blank_lines_after_class_header = 1
ij_java_blank_lines_before_class_end = 1

[{*.yaml,*.yml}]
indent_size = 4
